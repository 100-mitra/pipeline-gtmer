# ── LLM / embeddings ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# ── Supabase (Postgres + pgvector) ───────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # server-side only; never ship to the dashboard
SUPABASE_ANON_KEY=eyJ...                # used by the keep-alive cron

# ── Observability (Langfuse Cloud, free Hobby tier) ──────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Optional enrichment ──────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...                # JS-heavy sites only; 1,000 credits/mo
HUNTER_API_KEY=                         # top-10 last-mile only; 50 credits/mo

# ── Models & budget ──────────────────────────────────────────────
WRITER_MODEL=claude-haiku-4-5
JUDGE_MODEL=claude-sonnet-4-6
EMBED_MODEL=voyage-4-lite
EMBED_DIM=1024
BUDGET_RUN_USD=5.0
BUDGET_HARD_CAP_USD=20.0

# ── Pitch page (the only privacy mechanism for /for-gtmer) ───────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
FOR_GTMER_SLUG=

# ── Windows: cp1252 console breaks on LLM emoji / smart quotes ───
PYTHONUTF8=1
